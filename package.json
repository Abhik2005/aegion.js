    "@typescript-eslint/parser": "^8.62.1",
    "autocannon": "^8.0.0",
    "c8": "^11.0.0",
    "ejs": "^6.0.1",
    "eslint": "^8.57.1",
    "eslint-plugin-security": "^4.0.1",
    "mongoose": "^9.7.3",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0"
  }
