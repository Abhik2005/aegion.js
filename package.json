{
  "name": "aegion.js",
  "version": "1.0.0",
  "description": "Secure, enterprise-level Node.js server library with Functional Composition routing.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "author": "Abhik Mondal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/aegion.git"
  },
  "keywords": [
    "server",
    "framework",
    "composition",
    "security",
    "hash"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "tsx --test tests/*.test.ts",
    "coverage": "c8 npm run test",
