    "audit:ci": "npm audit --audit-level=high",
    "benchmark": "tsx tests/benchmark.ts"
  },
  "dependencies": {
    "@fastify/busboy": "^3.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
